# 由于在上面的回归模型中发现数据呈阶梯式分布，推测数据可能而是针对不同水平的学生进行了分层采样，所以我想看看具体是哪一类学生受社交媒体的影响最大，以此可以针对该类学生进行精准干预
group = ['lowwer','low','middle','high','higher']  #把学生分为[极差生，差生，中等生，优等生，天才]五个组

df['Group'] = pd.cut(df['current_sem_CGPA'],bins=[5,6,7,8,9,10],labels=group)  #按照成绩区间平均分组

result = {}
#针对每一组学生，分别建立一个微型回归模型
for name in group:
    df_sub = df[df['Group'] == name]
    if not df_sub.empty:
        x = df_sub[['social_media_hours']]
        y = df_sub['current_sem_CGPA']

        model = LinearRegression().fit(x,y)
        coef_ = model.coef_[0]

        result[name] = coef_
        print(f'对于{name}组的学生,当社交时间增加1小时时,成绩下降{coef_:.2f}')
#输出：
对于lowwer组的学生,当社交时间增加1小时时,成绩下降-0.05
对于low组的学生,当社交时间增加1小时时,成绩下降-0.44
对于middle组的学生,当社交时间增加1小时时,成绩下降-0.26
对于high组的学生,当社交时间增加1小时时,成绩下降0.01
对于higher组的学生,当社交时间增加1小时时,成绩下降-0.17

impacts = [(round(abs(result[group_sub]),2)) for group_sub in group]

cmap = plt.get_cmap('tab10')
colors = cmap(np.arange(len(group)))
plt.figure(figsize=(10,6))
bars = plt.bar(group,impacts,color=colors)
for bar in bars:
    yval = bar.get_height()
    plt.text(bar.get_x() + bar.get_width()/2, yval+0.01, f'{yval:.2f}',ha='center')
plt.ylabel('增加社交媒体时间对于成绩的影响系数', fontsize=12)
plt.xlabel('学生分类', fontsize=12)
plt.ylim(0,0.5)
plt.show()
#输出：Student_Performance_2026_picture7
